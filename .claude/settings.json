{
  "permissions": {
    "allow": [
      "Bash(pnpm dev)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build)",
      "Bash(pnpm preview)",
      "Bash(pnpm format)",
      "Bash(pnpm format:check)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm ci)",
      "Bash(pnpm openapi)",
      "Bash(pnpm install)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)",
      "Bash(pnpm dlx *)",
      "Bash(npx shadcn *)",
      "Bash(npx tsc --noEmit*)",
      "Bash(npx biome *)",
      "Bash(node *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git cherry-pick*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git remote*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh api *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(cat .claude/*)",
      "Bash(bash .claude/hooks/*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/fsd-layer-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
